{
  "name": "jman-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "yarn build && playwright test",
    "test:all": "yarn typecheck && yarn test && yarn test:e2e"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-feather": "^2.0.10"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.14"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "eslint",
      "prettier --write"
    ]
  },
  "resolutions": {
    "**/flatted": "^3.4.2",
    "**/picomatch": "^2.3.2",
    "eslint-config-next/**/minimatch": "^3.1.5",
    "eslint-plugin-import/minimatch": "^3.1.5",
    "eslint-plugin-jsx-a11y/minimatch": "^3.1.5",
    "eslint-plugin-react/minimatch": "^3.1.5",
    "minimatch/brace-expansion": "^1.1.13",
    "next/postcss": "^8.5.15"
  },
  "license": "MIT",
  "engines": {
    "node": "22.x"
  }
}
